<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso interno</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: linear-gradient(180deg, #0f1723 0%, #17263a 50%, #203754 100%);
        color: #e7eef8;
        font-family: "Segoe UI", sans-serif;
      }
      .panel {
        width: min(420px, calc(100vw - 32px));
        border-radius: 24px;
        padding: 32px;
        background: rgba(10, 17, 26, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
      }
      h1 {
        margin-top: 0;
      }
      .meta {
        margin-bottom: 18px;
        color: #9fb2c6;
      }
      .pill {
        display: inline-flex;
        margin-top: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(71, 104, 145, 0.24);
        font-size: 0.78rem;
      }
      form {
        display: grid;
        gap: 14px;
      }
      label {
        display: grid;
        gap: 6px;
        color: #aab8c6;
      }
      input, button {
        font: inherit;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.12);
      }
      input {
        background: rgba(255, 255, 255, 0.06);
        color: #f4f8fb;
      }
      button {
        border: 0;
        background: linear-gradient(135deg, #4f83c2 0%, #2d5d9b 100%);
        color: white;
        cursor: pointer;
        font-weight: 700;
      }
      .error {
        border-radius: 14px;
        padding: 12px 14px;
        background: rgba(181, 54, 54, 0.18);
        color: #ffd4d4;
      }
    </style>
  </head>
  <body>
    <section class="panel">
      <h1>Panel interno</h1>
      <p class="meta">
        Acceso para operadores y administración de CrossFit Atlas.
      </p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/login" method="post">
        <label>
          Usuario
          <input type="text" name="username" required>
        </label>
        <label>
          Contraseña
          <input type="password" name="password" required>
        </label>
        <button type="submit">Ingresar</button>
      </form>
    </section>
  </body>
</html>
