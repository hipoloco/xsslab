<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Token emitido</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #101924;
        color: #e7eef8;
        font-family: "Segoe UI", sans-serif;
      }
      .panel {
        width: min(760px, calc(100vw - 32px));
        border-radius: 24px;
        padding: 30px;
        background: rgba(12, 20, 30, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
      }
      code {
        display: block;
        padding: 16px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.06);
        color: #b8f1ff;
        word-break: break-all;
      }
      a.button {
        display: inline-flex;
        margin-top: 18px;
        text-decoration: none;
        padding: 11px 15px;
        border-radius: 12px;
        background: #2d5d9b;
        color: white;
      }
      .meta {
        color: #a2b4c8;
      }
    </style>
  </head>
  <body>
    <section class="panel">
      <h1>Token JWT emitido</h1>
      <p class="meta">
        Usuario autenticado: <strong><%= user.username %></strong>.
        Esta sesión interna usa autenticación explícita: el token debe adjuntarse en cada request.
      </p>
      <code><%= issuedToken %></code>
      <a class="button" href="<%= adminUrl %>">Continuar a /admin con el token</a>
    </section>
  </body>
</html>
